# =============================================
# CtrlZ-The-ADCB — Environment Variables
# =============================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env

# --- CLERK AUTHENTICATION ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# --- BACKEND ---
PORT=8000

# --- FRONTEND (API base URL for invoice pre-vet) ---
VITE_API_URL=http://localhost:8000

# --- OPENAI (for AHTN RAG embeddings) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: use text-embedding-3-large for higher Sim (requires rebuild)
# AHTN_EMBEDDING_MODEL=text-embedding-3-large
