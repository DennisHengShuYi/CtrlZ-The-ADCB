# --- SHARED/CLERK ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY
VITE_CLERK_FRONTEND_API=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev
CLERK_API_URL=https://api.clerk.com
CLERK_JWKS_URL=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev/.well-known/jwks.json

# PEM-formatted Public Key (single line, escaped newlines)
CLERK_JWKS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# --- BACKEND SPECIFIC ---
PORT=8000

# --- SUPABASE ---
USE_SUPABASE=true
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- GEMINI AI ---
GEMINI_API_KEY=

AUTH_STRATEGY=mock

# --- OPENAI (for AHTN RAG embeddings & LLM) ---
OPENAI_API_KEY=
# Optional: use text-embedding-3-large for higher Sim (requires rebuild)
# AHTN_EMBEDDING_MODEL=text-embedding-3-large
